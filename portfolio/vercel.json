{
  "version": 2,
  "builds": [
    {
      "src": "portfolio/pages/**/*.jsx",
      "use": "@vercel/node"
    },
    {
      "src": "portfolio/src/**/*.css",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "portfolio/src/(.*)",
      "dest": "portfolio/src/$1"
    }
  ]
}

